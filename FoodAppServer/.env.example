# .env.example
# Copy this file to `.env` and fill in real values. DO NOT commit real secrets to VCS.

# JWT secret used by the application
# This should be a sufficiently long random string. Keep it secret.
secreteJwtString=YOUR_JWT_SECRET_HERE

# Mail (Gmail) credentials used for sending emails
# If using Gmail with 2FA, create an App Password and use it here.
myGmail=your.email@example.com
myGmailPassword=your-gmail-app-password

# AWS credentials for S3 access
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-southeast-2
S3_BUCKET_NAME=your-s3-bucket-name

# Stripe keys (test keys shown as placeholders)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY

# Google OAuth2 credentials (for social login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
